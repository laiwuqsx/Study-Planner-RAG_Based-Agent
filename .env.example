# Server
HOST=0.0.0.0
PORT=8000

# Database
# Production/local Docker example. The provided docker-compose maps host port 5433.
# DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@127.0.0.1:5433/study_planner
DATABASE_URL=sqlite:///./study_planner.db

# Auth
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# Retrieval backend, used in later phases
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19531
MILVUS_COLLECTION=study_chunks
