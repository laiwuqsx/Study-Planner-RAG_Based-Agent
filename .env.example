# Server
HOST=0.0.0.0
PORT=8000

# Database
# PostgreSQL is the default target database for this project. The provided docker-compose maps host port 5433.
DATABASE_URL=postgresql+psycopg2://study_planner:change-me-local-only@127.0.0.1:5433/study_planner
# Optional local fallback for quick experiments only:
# DATABASE_URL=sqlite:///./study_planner.db

# Auth
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# Retrieval backend, used in later phases
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19531
MILVUS_COLLECTION=study_chunks

# Embeddings
# Use `voyage` for real embeddings. Use `hash` only for local smoke tests when you want a deterministic no-network fallback.
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-4-lite
EMBEDDING_DIMENSION=1024
VOYAGE_API_KEY=replace-with-your-voyage-api-key

# Chat
# `auto` uses the LLM provider only when CHAT_API_KEY is present. `extractive` forces the local fallback.
CHAT_PROVIDER=auto
CHAT_MODEL=gpt-4.1-mini
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_API_KEY=
CHAT_MAX_OUTPUT_TOKENS=500
